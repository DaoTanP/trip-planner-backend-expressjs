NODE_ENV=development
APP_NAME=trip-planner-api
APP_PORT=4000
API_HOST_PORT=4000
API_PREFIX=/api/v1

DATABASE_URL=postgresql://trip_planner:trip_planner_password@localhost:5432/trip_planner?schema=public
POSTGRES_DB=trip_planner
POSTGRES_USER=trip_planner
POSTGRES_PASSWORD=trip_planner_password
POSTGRES_PORT=5432

REDIS_URL=redis://localhost:6379
REDIS_PORT=6379

JWT_ACCESS_SECRET=replace-with-at-least-32-characters-access-secret
JWT_REFRESH_SECRET=replace-with-at-least-32-characters-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN_DAYS=30

AUTH_TOKEN_TRANSPORT=cookie
AUTH_ACCESS_COOKIE_NAME=tp_access_token
AUTH_REFRESH_COOKIE_NAME=tp_refresh_token
AUTH_CSRF_COOKIE_NAME=tp_csrf_token
AUTH_COOKIE_DOMAIN=
AUTH_COOKIE_SAME_SITE=lax
AUTH_COOKIE_SECURE=false

GOOGLE_OAUTH_CLIENT_ID=replace-with-google-oauth-web-client-id

CORS_ORIGINS=http://localhost:5173,http://localhost:3000
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300

S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=trip-planner-dev
S3_ACCESS_KEY_ID=local-access-key
S3_SECRET_ACCESS_KEY=local-secret-key
S3_FORCE_PATH_STYLE=true

MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_FROM=no-reply@trip-planner.local

LOG_LEVEL=debug
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025
