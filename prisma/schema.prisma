generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum UserStatus {
  PENDING_VERIFICATION
  ACTIVE
  DISABLED
}

enum AuthProvider {
  EMAIL
  GOOGLE
  GITHUB
  APPLE
}

enum TripVisibility {
  PRIVATE
  SHARED
  PUBLIC
}

enum TripRole {
  OWNER
  EDITOR
  VIEWER
}

enum TripStatus {
  DRAFT
  PLANNED
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum ItineraryItemStatus {
  PLANNED
  BOOKED
  COMPLETED
  CANCELLED

  @@map("ActivityStatus")
}

enum ItineraryItemType {
  ACTIVITY
  PLACE
  LODGING
  TRANSPORT
  FOOD
  NOTE
  TASK
  CUSTOM
}

enum CommentTargetType {
  TRIP
  DAY
  ACTIVITY
}

enum NotificationType {
  TRIP_INVITE
  COMMENT_MENTION
  ITINERARY_UPDATE
  SYSTEM
}

enum NotificationStatus {
  UNREAD
  READ
  ARCHIVED
}

enum PlaceProvider {
  MANUAL
  GOOGLE
  MAPBOX
  OSM
  INTERNAL

  @@map("PlaceSource")
}

enum RouteProvider {
  GOOGLE
  MAPBOX
  OSM
  INTERNAL
}

model User {
  id              String       @id @default(uuid()) @db.Uuid
  email           String       @unique @db.Citext
  passwordHash    String?      @db.Text
  name            String       @db.VarChar(120)
  avatarUrl       String?      @db.Text
  role            UserRole     @default(USER)
  status          UserStatus   @default(ACTIVE)
  emailVerifiedAt DateTime?
  locale          String       @default("en") @db.VarChar(16)
  timezone        String       @default("UTC") @db.VarChar(80)
  preferences     Json?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  oauthAccounts  OAuthAccount[]
  refreshTokens  RefreshToken[]
  ownedTrips     Trip[]             @relation("TripOwner")
  collaborations TripCollaborator[]
  comments       Comment[]
  notifications  Notification[]
  tripNotes      TripNote[]
  itineraryNotes ItineraryNote[]
  paidExpenses   Expense[]

  @@index([status])
  @@index([createdAt])
}

model OAuthAccount {
  id             String       @id @default(uuid()) @db.Uuid
  userId         String       @db.Uuid
  provider       AuthProvider
  providerUserId String       @db.VarChar(255)
  providerEmail  String?      @db.Citext
  profile        Json?
  lastLoginAt    DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@index([userId])
  @@index([providerEmail])
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  tokenHash String    @unique @db.VarChar(128)
  familyId  String    @db.Uuid
  deviceId  String?   @db.VarChar(128)
  userAgent String?   @db.Text
  ipAddress String?   @db.VarChar(64)
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([familyId])
  @@index([expiresAt])
}

model Trip {
  id            String         @id @default(uuid()) @db.Uuid
  ownerId       String         @db.Uuid
  title         String         @db.VarChar(180)
  description   String?        @db.Text
  startDate     DateTime?      @db.Date
  endDate       DateTime?      @db.Date
  timezone      String         @default("UTC") @db.VarChar(80)
  coverImageUrl String?        @db.Text
  visibility    TripVisibility @default(PRIVATE)
  status        TripStatus     @default(DRAFT)
  preferences   Json?
  legacyBudget  Json?          @map("budget")
  metadata      Json?
  version       Int            @default(1)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  owner             User                @relation("TripOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  destinations      Destination[]
  collaborators     TripCollaborator[]
  days              TripDay[]
  itineraryItems    ItineraryItem[]
  routeSegments     RouteSegment[]
  notes             TripNote[]
  itineraryNotes    ItineraryNote[]
  budgetRecord      Budget?
  expenseCategories ExpenseCategory[]
  expenses          Expense[]
  comments          Comment[]
  notifications     Notification[]

  @@index([ownerId])
  @@index([status])
  @@index([startDate])
}

model TripCollaborator {
  id           String    @id @default(uuid()) @db.Uuid
  tripId       String    @db.Uuid
  userId       String?   @db.Uuid
  invitedEmail String?   @db.Citext
  role         TripRole  @default(VIEWER)
  acceptedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  trip Trip  @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([tripId, userId])
  @@index([tripId])
  @@index([userId])
  @@index([invitedEmail])
}

model Destination {
  id            String    @id @default(uuid()) @db.Uuid
  tripId        String    @db.Uuid
  placeId       String?   @db.Uuid
  name          String    @db.VarChar(180)
  countryCode   String?   @db.VarChar(2)
  city          String?   @db.VarChar(120)
  latitude      Decimal?  @db.Decimal(9, 6)
  longitude     Decimal?  @db.Decimal(9, 6)
  arrivalDate   DateTime? @db.Date
  departureDate DateTime? @db.Date
  order         Int       @default(0)
  notes         String?   @db.Text
  metadata      Json?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  trip  Trip   @relation(fields: [tripId], references: [id], onDelete: Cascade)
  place Place? @relation(fields: [placeId], references: [id], onDelete: SetNull)

  @@index([tripId, order])
  @@index([placeId])
}

model TripDay {
  id              String    @id @default(uuid()) @db.Uuid
  tripId          String    @db.Uuid
  date            DateTime  @db.Date
  title           String?   @db.VarChar(160)
  notes           String?   @db.Text
  order           Int       @default(0)
  weatherSnapshot Json?
  version         Int       @default(1)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  trip        Trip            @relation(fields: [tripId], references: [id], onDelete: Cascade)
  legacyItems ItineraryItem[] @relation("LegacyItineraryItemDay")
  comments    Comment[]

  @@unique([tripId, date])
  @@index([tripId, order])
  @@map("ItineraryDay")
}

model ItineraryItem {
  id                  String              @id @default(uuid()) @db.Uuid
  tripId              String              @db.Uuid
  legacyDayId         String?             @map("dayId") @db.Uuid
  placeId             String?             @db.Uuid
  routeSegmentId      String?             @db.Uuid
  type                ItineraryItemType   @default(ACTIVITY)
  title               String              @db.VarChar(180)
  description         String?             @db.Text
  timezone            String              @default("UTC") @db.VarChar(80)
  startTime           DateTime?
  endTime             DateTime?
  isFlexibleTime      Boolean             @default(true)
  isAllDay            Boolean             @default(false)
  sortOrder           Int                 @default(0)
  status              ItineraryItemStatus @default(PLANNED)
  cost                Decimal?            @db.Decimal(12, 2)
  currency            String?             @db.VarChar(3)
  durationMinutes     Int?
  travelMode          String?             @db.VarChar(40)
  travelTimeMinutes   Int?
  routePolyline       String?             @db.Text
  bookingInfo         Json?
  metadata            Json?
  version             Int                 @default(1)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  deletedAt           DateTime?

  trip         Trip             @relation(fields: [tripId], references: [id], onDelete: Cascade)
  legacyDay    TripDay?         @relation("LegacyItineraryItemDay", fields: [legacyDayId], references: [id], onDelete: SetNull)
  place        Place?           @relation(fields: [placeId], references: [id], onDelete: SetNull)
  routeSegment RouteSegment?    @relation(fields: [routeSegmentId], references: [id], onDelete: SetNull)
  notes        ItineraryNote[]
  expenses     Expense[]
  comments     Comment[]

  @@index([tripId, deletedAt, sortOrder])
  @@index([tripId, status])
  @@index([legacyDayId])
  @@index([placeId])
  @@index([routeSegmentId])
  @@index([status])
  @@map("Activity")
}

model Place {
  id               String        @id @default(uuid()) @db.Uuid
  provider         PlaceProvider @default(MANUAL) @map("source")
  providerPlaceId  String?       @map("externalId") @db.VarChar(255)
  name             String      @db.VarChar(180)
  address          String?     @db.Text
  formattedAddress String?     @db.Text
  countryCode      String?     @db.VarChar(2)
  latitude         Decimal?    @db.Decimal(9, 6)
  longitude        Decimal?    @db.Decimal(9, 6)
  websiteUrl       String?     @db.Text
  phoneNumber      String?     @db.VarChar(40)
  timezone         String?     @db.VarChar(80)
  categories       String[]    @default([])
  providerPayload  Json?       @map("sourcePayload")
  metadata         Json?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  destinations      Destination[]
  itineraryItems    ItineraryItem[]
  routeSegmentsFrom RouteSegment[] @relation("RouteFromPlace")
  routeSegmentsTo   RouteSegment[] @relation("RouteToPlace")

  @@unique([provider, providerPlaceId])
  @@index([name])
  @@index([countryCode])
  @@index([latitude, longitude])
}

model RouteSegment {
  id              String        @id @default(uuid()) @db.Uuid
  tripId          String?       @db.Uuid
  fromPlaceId     String        @db.Uuid
  toPlaceId       String        @db.Uuid
  provider        RouteProvider
  polyline        String        @db.Text
  distanceMeters  Int?
  durationSeconds Int?
  metadata        Json?
  createdAt       DateTime      @default(now())

  trip             Trip?           @relation(fields: [tripId], references: [id], onDelete: Cascade)
  fromPlace        Place           @relation("RouteFromPlace", fields: [fromPlaceId], references: [id], onDelete: Cascade)
  toPlace          Place           @relation("RouteToPlace", fields: [toPlaceId], references: [id], onDelete: Cascade)
  itineraryItems   ItineraryItem[]

  @@unique([provider, fromPlaceId, toPlaceId])
  @@index([tripId])
  @@index([fromPlaceId, toPlaceId])
}

model TripNote {
  id        String   @id @default(uuid()) @db.Uuid
  tripId    String   @db.Uuid
  authorId  String?  @db.Uuid
  title     String?  @db.VarChar(160)
  body      String   @db.Text
  order     Int      @default(0)
  pinned    Boolean  @default(false)
  metadata  Json?
  version   Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trip   Trip  @relation(fields: [tripId], references: [id], onDelete: Cascade)
  author User? @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@index([tripId, order])
  @@index([authorId])
}

model ItineraryNote {
  id              String   @id @default(uuid()) @db.Uuid
  tripId          String   @db.Uuid
  itineraryItemId String   @db.Uuid
  authorId        String?  @db.Uuid
  body            String   @db.Text
  metadata        Json?
  version         Int      @default(1)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  trip          Trip          @relation(fields: [tripId], references: [id], onDelete: Cascade)
  itineraryItem ItineraryItem @relation(fields: [itineraryItemId], references: [id], onDelete: Cascade)
  author        User?         @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@index([tripId, createdAt])
  @@index([itineraryItemId, createdAt])
  @@index([authorId])
}

model Budget {
  id           String   @id @default(uuid()) @db.Uuid
  tripId       String   @unique @db.Uuid
  currency     String   @default("USD") @db.VarChar(3)
  totalLimit   Decimal? @db.Decimal(12, 2)
  metadata     Json?
  version      Int      @default(1)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  trip     Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)
  expenses Expense[]

  @@index([tripId])
}

model ExpenseCategory {
  id        String   @id @default(uuid()) @db.Uuid
  tripId    String   @db.Uuid
  name      String   @db.VarChar(120)
  color     String?  @db.VarChar(32)
  sortOrder Int      @default(0)
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trip     Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)
  expenses Expense[]

  @@unique([tripId, name])
  @@index([tripId, sortOrder])
}

model Expense {
  id              String   @id @default(uuid()) @db.Uuid
  tripId          String   @db.Uuid
  budgetId        String?  @db.Uuid
  categoryId      String?  @db.Uuid
  itineraryItemId String?  @db.Uuid
  title           String   @db.VarChar(180)
  amount          Decimal  @db.Decimal(12, 2)
  currency        String   @db.VarChar(3)
  paidByUserId    String?  @db.Uuid
  spentAt         DateTime?
  notes           String?  @db.Text
  metadata        Json?
  version         Int      @default(1)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?

  trip          Trip             @relation(fields: [tripId], references: [id], onDelete: Cascade)
  budget        Budget?          @relation(fields: [budgetId], references: [id], onDelete: SetNull)
  category      ExpenseCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  itineraryItem ItineraryItem?    @relation(fields: [itineraryItemId], references: [id], onDelete: SetNull)
  paidByUser    User?            @relation(fields: [paidByUserId], references: [id], onDelete: SetNull)

  @@index([tripId, deletedAt, spentAt])
  @@index([budgetId])
  @@index([categoryId])
  @@index([itineraryItemId])
  @@index([paidByUserId])
}

model Comment {
  id         String            @id @default(uuid()) @db.Uuid
  authorId   String            @db.Uuid
  tripId     String            @db.Uuid
  dayId      String?           @db.Uuid
  activityId String?           @db.Uuid
  targetType CommentTargetType
  body       String            @db.Text
  metadata   Json?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  author   User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  trip     Trip          @relation(fields: [tripId], references: [id], onDelete: Cascade)
  day      TripDay?        @relation(fields: [dayId], references: [id], onDelete: Cascade)
  activity ItineraryItem?  @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@index([tripId, createdAt])
  @@index([dayId])
  @@index([activityId])
  @@index([authorId])
}

model Notification {
  id        String             @id @default(uuid()) @db.Uuid
  userId    String             @db.Uuid
  tripId    String?            @db.Uuid
  type      NotificationType
  status    NotificationStatus @default(UNREAD)
  title     String             @db.VarChar(180)
  body      String?            @db.Text
  data      Json?
  readAt    DateTime?
  createdAt DateTime           @default(now())

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  trip Trip? @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([userId, status, createdAt])
  @@index([tripId])
}
