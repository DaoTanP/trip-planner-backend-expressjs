generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum UserStatus {
  PENDING_VERIFICATION
  ACTIVE
  DISABLED
}

enum AuthProvider {
  EMAIL
  GOOGLE
  GITHUB
  APPLE
}

enum TripVisibility {
  PRIVATE
  SHARED
  PUBLIC
}

enum TripRole {
  OWNER
  EDITOR
  VIEWER
}

enum TripStatus {
  DRAFT
  PLANNED
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum ItineraryItemStatus {
  PLANNED
  BOOKED
  COMPLETED
  CANCELLED

  @@map("ActivityStatus")
}

enum ItineraryItemType {
  ACTIVITY
  PLACE
  LODGING
  TRANSPORT
  FOOD
  NOTE
  TASK
  CUSTOM
}

enum NotificationStatus {
  UNREAD
  READ
  ARCHIVED
}

enum PlaceProvider {
  MANUAL
  GOOGLE
  MAPBOX
  OSM
  INTERNAL

  @@map("PlaceSource")
}

enum RouteProvider {
  GOOGLE
  MAPBOX
  OSM
  INTERNAL
}

model User {
  id              String       @id @default(uuid()) @db.Uuid
  email           String       @unique @db.Citext
  passwordHash    String?      @db.Text
  name            String       @db.VarChar(120)
  avatarUrl       String?      @db.Text
  role            UserRole     @default(USER)
  status          UserStatus   @default(ACTIVE)
  emailVerifiedAt DateTime?
  locale          String       @default("en") @db.VarChar(16)
  timezone        String       @default("UTC") @db.VarChar(80)
  preferences     Json?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  oauthAccounts  OAuthAccount[]
  refreshTokens  RefreshToken[]
  ownedTrips     Trip[]             @relation("TripOwner")
  collaborations TripCollaborator[]
  comments       Comment[]
  notifications  Notification[]
  notes          Note[]
  clientMutations ClientMutation[]
  paidExpenses   Expense[]

  @@index([status])
  @@index([createdAt])
}

model OAuthAccount {
  id             String       @id @default(uuid()) @db.Uuid
  userId         String       @db.Uuid
  provider       AuthProvider
  providerUserId String       @db.VarChar(255)
  providerEmail  String?      @db.Citext
  profile        Json?
  lastLoginAt    DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@index([userId])
  @@index([providerEmail])
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  tokenHash String    @unique @db.VarChar(128)
  familyId  String    @db.Uuid
  deviceId  String?   @db.VarChar(128)
  userAgent String?   @db.Text
  ipAddress String?   @db.VarChar(64)
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([familyId])
  @@index([expiresAt])
}

model Trip {
  id            String         @id @default(uuid()) @db.Uuid
  ownerId       String         @db.Uuid
  title         String         @db.VarChar(180)
  description   String?        @db.Text
  startDate     DateTime?      @db.Date
  endDate       DateTime?      @db.Date
  timezone      String         @default("UTC") @db.VarChar(80)
  coverImageUrl String?        @db.Text
  visibility    TripVisibility @default(PRIVATE)
  status        TripStatus     @default(DRAFT)
  preferences   Json?
  legacyBudget  Json?          @map("budget")
  metadata      Json?
  version       Int            @default(1)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  owner             User                @relation("TripOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  collaborators     TripCollaborator[]
  itineraryItems    ItineraryItem[]
  routeSegments     RouteSegment[]
  notes             Note[]
  budgetRecord      Budget?
  expenseCategories ExpenseCategory[]
  expenses          Expense[]
  comments          Comment[]
  notifications     Notification[]
  clientMutations   ClientMutation[]

  @@index([ownerId])
  @@index([status])
  @@index([startDate])
}

model TripCollaborator {
  id           String    @id @default(uuid()) @db.Uuid
  tripId       String    @db.Uuid
  userId       String?   @db.Uuid
  invitedEmail String?   @db.Citext
  role         TripRole  @default(VIEWER)
  acceptedAt   DateTime?
  version      Int       @default(1)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?
  lastClientMutationId String? @db.VarChar(120)

  trip Trip  @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([tripId, userId])
  @@index([tripId, deletedAt])
  @@index([userId])
  @@index([invitedEmail])
}

model ItineraryItem {
  id                  String              @id @default(uuid()) @db.Uuid
  tripId              String              @db.Uuid
  placeId             String?             @db.Uuid
  routeSegmentId      String?             @db.Uuid
  type                ItineraryItemType   @default(ACTIVITY)
  title               String              @db.VarChar(180)
  description         String?             @db.Text
  timezone            String              @default("UTC") @db.VarChar(80)
  startTime           DateTime?
  endTime             DateTime?
  isFlexibleTime      Boolean             @default(true)
  isAllDay            Boolean             @default(false)
  sortOrder           Int                 @default(0)
  status              ItineraryItemStatus @default(PLANNED)
  cost                Decimal?            @db.Decimal(12, 2)
  currency            String?             @db.VarChar(3)
  durationMinutes     Int?
  bookingInfo         Json?
  metadata            Json?
  version             Int                 @default(1)
  lastClientMutationId String?             @db.VarChar(120)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  deletedAt           DateTime?

  trip         Trip             @relation(fields: [tripId], references: [id], onDelete: Cascade)
  place        Place?           @relation(fields: [placeId], references: [id], onDelete: SetNull)
  routeSegment RouteSegment?    @relation(fields: [routeSegmentId], references: [id], onDelete: SetNull)
  expenses     Expense[]

  @@index([tripId, deletedAt, sortOrder, id])
  @@index([tripId, status])
  @@index([placeId])
  @@index([routeSegmentId])
  @@index([status])
  @@map("Activity")
}

model Place {
  id               String        @id @default(uuid()) @db.Uuid
  provider         PlaceProvider @default(MANUAL) @map("source")
  providerPlaceId  String?       @map("externalId") @db.VarChar(255)
  name             String      @db.VarChar(180)
  address          String?     @db.Text
  formattedAddress String?     @db.Text
  countryCode      String?     @db.VarChar(2)
  latitude         Decimal?    @db.Decimal(9, 6)
  longitude        Decimal?    @db.Decimal(9, 6)
  websiteUrl       String?     @db.Text
  phoneNumber      String?     @db.VarChar(40)
  timezone         String?     @db.VarChar(80)
  categories       String[]    @default([])
  providerPayload  Json?       @map("sourcePayload")
  metadata         Json?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  itineraryItems    ItineraryItem[]
  routeSegmentsFrom RouteSegment[] @relation("RouteFromPlace")
  routeSegmentsTo   RouteSegment[] @relation("RouteToPlace")

  @@unique([provider, providerPlaceId])
  @@index([name])
  @@index([countryCode])
  @@index([latitude, longitude])
}

model RouteSegment {
  id              String        @id @default(uuid()) @db.Uuid
  tripId          String?       @db.Uuid
  fromPlaceId     String        @db.Uuid
  toPlaceId       String        @db.Uuid
  provider        RouteProvider
  travelMode      String        @default("driving") @db.VarChar(40)
  routeProfileHash String       @default("default") @db.VarChar(128)
  polyline        String        @db.Text
  distanceMeters  Int?
  durationSeconds Int?
  metadata        Json?
  version         Int           @default(1)
  lastClientMutationId String?  @db.VarChar(120)
  expiresAt       DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  deletedAt       DateTime?

  trip             Trip?           @relation(fields: [tripId], references: [id], onDelete: Cascade)
  fromPlace        Place           @relation("RouteFromPlace", fields: [fromPlaceId], references: [id], onDelete: Cascade)
  toPlace          Place           @relation("RouteToPlace", fields: [toPlaceId], references: [id], onDelete: Cascade)
  itineraryItems   ItineraryItem[]

  @@unique([provider, fromPlaceId, toPlaceId, travelMode, routeProfileHash])
  @@index([tripId, deletedAt, createdAt])
  @@index([tripId, provider, travelMode])
  @@index([fromPlaceId, toPlaceId])
  @@index([expiresAt])
}

model Note {
  id               String   @id @default(uuid()) @db.Uuid
  tripId           String   @db.Uuid
  authorId         String?  @db.Uuid
  targetEntityType String   @db.VarChar(80)
  targetEntityId   String   @db.Uuid
  body             String   @db.Text
  metadata         Json?
  version          Int      @default(1)
  lastClientMutationId String? @db.VarChar(120)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  deletedAt        DateTime?

  trip   Trip  @relation(fields: [tripId], references: [id], onDelete: Cascade)
  author User? @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@index([tripId, deletedAt, createdAt, id])
  @@index([tripId, targetEntityType, targetEntityId, deletedAt, createdAt])
  @@index([authorId])
}

model Budget {
  id           String   @id @default(uuid()) @db.Uuid
  tripId       String   @unique @db.Uuid
  currency     String   @default("USD") @db.VarChar(3)
  totalLimit   Decimal? @db.Decimal(12, 2)
  metadata     Json?
  version      Int      @default(1)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  trip     Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)
  expenses Expense[]

  @@index([tripId])
}

model ExpenseCategory {
  id        String   @id @default(uuid()) @db.Uuid
  tripId    String   @db.Uuid
  name      String   @db.VarChar(120)
  color     String?  @db.VarChar(32)
  sortOrder Int      @default(0)
  metadata  Json?
  version   Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
  lastClientMutationId String? @db.VarChar(120)

  trip     Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)
  expenses Expense[]

  @@unique([tripId, name])
  @@index([tripId, deletedAt, sortOrder])
}

model Expense {
  id              String   @id @default(uuid()) @db.Uuid
  tripId          String   @db.Uuid
  budgetId        String?  @db.Uuid
  categoryId      String?  @db.Uuid
  itineraryItemId String?  @db.Uuid
  title           String   @db.VarChar(180)
  amount          Decimal  @db.Decimal(12, 2)
  currency        String   @db.VarChar(3)
  paidByUserId    String?  @db.Uuid
  spentAt         DateTime?
  notes           String?  @db.Text
  metadata        Json?
  version         Int      @default(1)
  lastClientMutationId String? @db.VarChar(120)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?

  trip          Trip             @relation(fields: [tripId], references: [id], onDelete: Cascade)
  budget        Budget?          @relation(fields: [budgetId], references: [id], onDelete: SetNull)
  category      ExpenseCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  itineraryItem ItineraryItem?    @relation(fields: [itineraryItemId], references: [id], onDelete: SetNull)
  paidByUser    User?            @relation(fields: [paidByUserId], references: [id], onDelete: SetNull)

  @@index([tripId, deletedAt, spentAt])
  @@index([budgetId])
  @@index([categoryId])
  @@index([itineraryItemId])
  @@index([paidByUserId])
}

model Comment {
  id               String   @id @default(uuid()) @db.Uuid
  authorId         String   @db.Uuid
  tripId           String   @db.Uuid
  targetEntityType String   @db.VarChar(80)
  targetEntityId   String   @db.Uuid
  body             String   @db.Text
  metadata         Json?
  version          Int      @default(1)
  lastClientMutationId String? @db.VarChar(120)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  deletedAt        DateTime?

  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)
  trip   Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId, deletedAt, createdAt])
  @@index([tripId, targetEntityType, targetEntityId, deletedAt, createdAt])
  @@index([authorId])
}

model ClientMutation {
  id               String   @id @default(uuid()) @db.Uuid
  tripId           String   @db.Uuid
  actorId          String?  @db.Uuid
  clientMutationId String   @db.VarChar(120)
  entityType       String   @db.VarChar(80)
  entityId         String?  @db.Uuid
  operation        String   @db.VarChar(80)
  createdAt        DateTime @default(now())

  trip  Trip  @relation(fields: [tripId], references: [id], onDelete: Cascade)
  actor User? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@unique([tripId, clientMutationId])
  @@index([tripId, createdAt])
  @@index([entityType, entityId])
  @@index([actorId])
}

model Notification {
  id               String             @id @default(uuid()) @db.Uuid
  userId           String             @db.Uuid
  tripId           String?            @db.Uuid
  notificationCode String             @db.VarChar(120)
  status           NotificationStatus @default(UNREAD)
  params           Json?
  readAt           DateTime?
  createdAt        DateTime           @default(now())

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  trip Trip? @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([userId, status, createdAt])
  @@index([tripId])
}
